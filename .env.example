# 🕌 Environment Configuration - Pondok Pesantren System
# Copy this file to .env and update the values

# ============================================
# DATABASE CONFIGURATION
# ============================================

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pesantren_db
DB_USER=pesantren
DB_PASSWORD=Pesantren2026!
DB_SSL=false

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=RedisPesantren2026!
REDIS_DB=0

# ============================================
# APPLICATION CONFIGURATION
# ============================================

# Backend API (NestJS)
NODE_ENV=development
API_PORT=3000
API_URL=http://localhost:3000
API_PREFIX=/api
CORS_ORIGIN=http://localhost:3001

# Admin Panel (Laravel)
APP_NAME="Sistem Informasi Pondok Pesantren"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_KEY=

# Web Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_APP_NAME="Portal Pesantren"
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ============================================
# AUTHENTICATION & SECURITY
# ============================================

# JWT Configuration
JWT_SECRET=JwtSecretPesantren2026SecureKeyChangeThisInProduction
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=RefreshSecretPesantren2026SecureKeyChangeThisInProduction
JWT_REFRESH_EXPIRES_IN=7d

# Password Hashing
BCRYPT_SALT_ROUNDS=12

# Session Configuration
SESSION_SECRET=SessionSecretPesantren2026SecureKeyChangeThisInProduction
SESSION_EXPIRES=86400 # 24 hours in seconds

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================

# File Upload Limits
MAX_FILE_SIZE=52428800 # 50MB in bytes
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# Upload Directories
UPLOAD_DIR=./uploads
STUDENT_PHOTOS_DIR=./uploads/students
DOCUMENTS_DIR=./uploads/documents
REPORTS_DIR=./uploads/reports

# ============================================
# EMAIL CONFIGURATION
# ============================================

# SMTP Configuration
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@pesantren.local
MAIL_FROM_NAME="Sistem Informasi Pesantren"

# ============================================
# PAYMENT GATEWAY INTEGRATION
# ============================================

# Midtrans (Sandbox)
MIDTRANS_SERVER_KEY=SB-Mid-server-YourServerKey
MIDTRANS_CLIENT_KEY=SB-Mid-client-YourClientKey
MIDTRANS_IS_PRODUCTION=false

# Xendit (Sandbox)
XENDIT_SECRET_KEY=xnd_development_YourSecretKey
XENDIT_PUBLIC_KEY=xnd_public_development_YourPublicKey

# QRIS Configuration
QRIS_MERCHANT_ID=YourMerchantID
QRIS_SECRET_KEY=YourQRISSecretKey

# ============================================
# WHATSAPP/TELEGRAM INTEGRATION
# ============================================

# WhatsApp Business API
WHATSAPP_API_URL=https://graph.facebook.com/v17.0
WHATSAPP_PHONE_NUMBER_ID=YourPhoneNumberID
WHATSAPP_ACCESS_TOKEN=YourAccessToken
WHATSAPP_VERIFY_TOKEN=YourVerifyToken

# Telegram Bot
TELEGRAM_BOT_TOKEN=YourTelegramBotToken
TELEGRAM_CHAT_ID=YourChatID

# ============================================
# MONITORING & ANALYTICS
# ============================================

# Sentry Error Tracking
SENTRY_DSN=YourSentryDSN
SENTRY_ENVIRONMENT=development

# Google Analytics
GA_MEASUREMENT_ID=G-YourMeasurementID

# ============================================
# THIRD-PARTY SERVICES
# ============================================

# Google Maps API
GOOGLE_MAPS_API_KEY=YourGoogleMapsAPIKey

# Cloud Storage (Optional)
CLOUD_STORAGE_PROVIDER=local # local, s3, gcs, azure
AWS_ACCESS_KEY_ID=YourAWSAccessKey
AWS_SECRET_ACCESS_KEY=YourAWSSecretKey
AWS_REGION=ap-southeast-1
AWS_BUCKET_NAME=pesantren-uploads

# ============================================
# DEVELOPMENT SETTINGS
# ============================================

# Debug Settings
DEBUG=true
LOG_LEVEL=debug
QUERY_DEBUG=true

# Seed Data
SEED_ADMIN_EMAIL=admin@pesantren.local
SEED_ADMIN_PASSWORD=AdminPesantren2026!
SEED_TEST_DATA=true

# ============================================
# SYSTEM SETTINGS
# ============================================

# Timezone
TIMEZONE=Asia/Jakarta

# Locale
LOCALE=id_ID
FALLBACK_LOCALE=en

# Date Format
DATE_FORMAT=DD/MM/YYYY
DATETIME_FORMAT=DD/MM/YYYY HH:mm:ss

# ============================================
# BACKUP CONFIGURATION
# ============================================

# Backup Settings
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * * # Daily at 2 AM
BACKUP_RETENTION_DAYS=7
BACKUP_DIR=/opt/pesantren-backups

# ============================================
# RATE LIMITING
# ============================================

# API Rate Limits
RATE_LIMIT_WINDOW=900000 # 15 minutes in milliseconds
RATE_LIMIT_MAX=100 # Max requests per window
RATE_LIMIT_AUTH_WINDOW=60000 # 1 minute for auth endpoints
RATE_LIMIT_AUTH_MAX=5 # Max auth attempts per minute

# ============================================
# FEATURE FLAGS
# ============================================

# Enable/Disable Features
FEATURE_WHATSAPP_NOTIFICATIONS=true
FEATURE_PAYMENT_GATEWAY=true
FEATURE_BIOMETRIC_ATTENDANCE=false
FEATURE_AI_ANALYTICS=false
FEATURE_MOBILE_APP=true
FEATURE_MULTI_TENANT=false

# ============================================
# SECURITY HEADERS
# ============================================

# Security Settings
ENABLE_CSP=true
ENABLE_HSTS=true
ENABLE_XSS_PROTECTION=true
ENABLE_NOSNIFF=true
ENABLE_FRAME_GUARD=true

# ============================================
# LOGGING CONFIGURATION
# ============================================

# Log Settings
LOG_CHANNEL=stack
LOG_STACK=single,daily
LOG_LEVEL_CHANNEL=daily
LOG_DAYS=14

# Log Paths
LOG_PATH=./logs
API_LOG_PATH=./logs/api
ADMIN_LOG_PATH=./logs/admin
WEB_LOG_PATH=./logs/web

# ============================================
# PERFORMANCE SETTINGS
# ============================================

# Cache Settings
CACHE_DRIVER=redis
CACHE_TTL=3600 # 1 hour in seconds
CACHE_PREFIX=pesantren_

# Database Pool
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_POOL_IDLE=10000 # 10 seconds in milliseconds

# ============================================
# MOBILE APP CONFIGURATION
# ============================================

# Firebase Cloud Messaging
FCM_SERVER_KEY=YourFCMServerKey
FCM_SENDER_ID=YourFCMSenderID

# App Links
ANDROID_PACKAGE_NAME=com.pesantren.app
IOS_BUNDLE_ID=com.pesantren.app
DEEP_LINK_SCHEME=pesantren

# ============================================
# SUPPORT CONTACTS
# ============================================

# Support Information
SUPPORT_EMAIL=support@pesantren.local
SUPPORT_PHONE=+6282115156464
SUPPORT_WHATSAPP=+6282115156464
SUPPORT_TELEGRAM=@pesantren_support

# ============================================
# VERSION INFORMATION
# ============================================

# System Version
APP_VERSION=1.0.0
API_VERSION=v1
BUILD_DATE=2026-04-04
BUILD_NUMBER=1